{
  "manifest_version": 3,
  "name": "OpenTTS Browser Extension",
  "version": "1.3.0",
  "description": "Speechify-style browser reading with OpenRouter TTS.",
  "background": {
    "service_worker": "src/background/service_worker.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "offscreen",
    "tabs",
    "contextMenus",
    "alarms"
  ],
  "host_permissions": [
    "https://openrouter.ai/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/loader.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/options/options.html",
  "web_accessible_resources": [
    {
      "resources": [
        "src/content/content_script.js",
        "src/content/button_injector.js",
        "src/content/hud.js",
        "src/content/auto_scroll.js",
        "src/content/paragraph_detector.js",
        "src/shared/message_types.js",
        "src/shared/storage.js",
        "src/shared/storage_keys.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "use_dynamic_url": true
    }
  ]
}
